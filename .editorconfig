root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ino,h,cpp,c,hpp}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# Large binary-ish SROM blobs — leave untouched
[srom_dummy_blank.h]
indent_style = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

[srom_3360_*.h]
indent_style = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
